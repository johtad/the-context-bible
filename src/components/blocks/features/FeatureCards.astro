---
// Feature Cards grid Section
// ------------
// Description: A grid of cards with feature information in a 4 column layout.

// Components
// - Layout
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - UI
import Card from '../../ui/cards/FeatureCard.astro'
---

<Section id="features">
	<Row>
		<Col span="12" align="center" classes="mb-12 max-w-4xl mx-auto">
			<h2 class="text-pretty">Built for readers who want to <strong>understand</strong>, not just read</h2>
			<p class="pb-0 text-lg">
				The Bible was written into a context — a time, a place, a people. The Context Bible
				brings that context to every verse, so the text reads with the depth it was written with.
			</p>
		</Col>
	</Row>
	<Row>
		<Col span="4">
			<Card
				title="Context panels for every verse"
				subtitle="Tap any passage to see its historical setting, theological tradition, early church reception, and academic discourse — side by side with the text."
				icon="book"
				link="/features"
			/>
		</Col>
		<Col span="4" classes="flex flex-col gap-6">
			<Card
				title="Ask Bible questions, get real citations"
				subtitle="Get answers grounded in scholarly sources, not guesses. Every response shows you where it came from."
				icon="chat-bubble-left-right"
				link="/features"
			/>
			<Card
				title="Beautiful verse cards to share"
				subtitle="Turn what speaks to you into shareable images for Instagram, Stories, or wherever you talk with friends."
				icon="eye"
				link="/features"
			/>
		</Col>
		<Col span="4" classes="flex flex-col gap-6">
			<Card
				title="Weekly Context insights"
				subtitle="A new themed deep-dive each week, surfacing the cultural and historical layers behind the passages you're reading."
				icon="filled-star"
				link="/features"
			/>
			<Card
				title="Verse of the Day"
				subtitle="A daily verse delivered to your phone — with the context that makes it land."
				icon="sun"
				link="/features"
			/>
		</Col>
	</Row>
</Section>
