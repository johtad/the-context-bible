---
// Home page CTA Section
// ------------
// Description: Hero section with headline, subhead, primary CTA, and screenshot.

// Components
// - Layout
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - UI
import ChipNotification from '../../ui/ChipNotification.astro'
import { Image } from 'astro:assets'
import Button from '../../ui/Button.astro'

// Content
// - Hero Image (placeholder — swap with an app screenshot when ready)
import heroImage from '../../../assets/hero-01.png'
---

<Section id="intro" padding="top" classes="bg-neutral-50 dark:bg-neutral-900">
	<Row>
		<Col span="2" />
		<Col span="8" align="center">
			<ChipNotification radius="rounded-full" classes="mb-6">
				Now available on iOS and Android
			</ChipNotification>
			<h1>Read Scripture in its <strong>original context</strong></h1>

			<p class="pb-0 text-lg">
				Every verse comes with the historical setting, early church interpretation,
				and academic discourse it deserves.
			</p>
			<Button size="lg" link="/app">Download free</Button>
		</Col>
		<Col span="2" />
		<Col span="2" />
		<Col span="8">
			<Image
				src={heroImage}
				alt="The Context Bible app"
				class="translate-y-8 shadow-2xl shadow-neutral-200 dark:shadow-neutral-950"
				format="webp"
			/></Col
		>
		<Col span="2" />
	</Row>
</Section>
