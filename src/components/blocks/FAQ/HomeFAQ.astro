---
// Home FAQ Section
// ----------------
// Description: A two-column FAQ block for the homepage. Left column is a
// sticky intro framing the questions pastorally; right column stacks an
// accordion of 10 common concerns about using historical/scholarly context
// in Bible reading, answered with Scripture.

// Components
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import Accordion from '../../ui/Accordion.astro'
import Card from '../../ui/cards/partials/Card.astro'
import Button from '../../ui/Button.astro'

import { homeFaqs as faqs } from '../../../data/homeFaqs'
---

<Section id="home-faq" stickyCol classes="bg-neutral-50 dark:bg-neutral-900">
	<Row>
		<Col span="4" classes="self-start">
			<div class="lg:sticky lg:top-24">
				<h2 class="text-pretty">
					Why do I need to <strong>study context?</strong>
				</h2>
				<p class="text-lg leading-relaxed">
					Honest questions about bringing history, scholarship, and the early
					church into your Bible reading — answered from Scripture itself.
				</p>
				<div class="mt-6">
					<Button link="/faq" style="secondary">See all FAQs</Button>
				</div>
			</div>
		</Col>
		<Col span="8">
			<Card classes="divide-y divide-neutral-100 dark:divide-neutral-800">
				{faqs.map((item) => (
					<Accordion title={item.q} text={item.a} open={item.open} />
				))}
			</Card>
		</Col>
	</Row>
</Section>
