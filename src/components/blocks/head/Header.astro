---
// Imports
import { ClientRouter } from 'astro:transitions'
import GoogleAnalytics from '../../scripts/googleAnalytics.astro'
import GoogleTagManagerHead from '../../scripts/googleTagManagerHead.astro'
import GoogleSearchConsole from '../../scripts/googleSearchConsole.astro'
import SchemaOrg from '../../scripts/SchemaOrg.astro'
// Partials
import Seo from './partials/Seo.astro'
// Data
import { configData } from '../../../config/config'

import { googleAnalyticsMeasurementID } from '../../../config/analytics'
import { googleTagManagerID } from '../../../config/analytics'

// Props
type Props = {
	title?: string
	description?: string
	ogImage?: string
	canonical?: boolean
	noindex?: boolean
}
// Page Metadata
const {
	title = configData.siteTitle,
	description = configData.siteDescription,
	ogImage: ogImageProp,
	canonical = configData.canonical,
	noindex = configData.noindex
} = Astro.props

// Per-page OG image generation. The OG endpoint at src/pages/og/[...route].png.ts
// renders PNGs for the keys listed below; any unregistered path falls back to the
// site default. og:image must be an absolute URL for social scrapers.
const STATIC_OG_KEYS = new Set([
	'index',
	'features',
	'faq',
	'app',
	'read',
	'contact',
	'terms',
	'blog'
])

const trimmedPath = Astro.url.pathname.replace(/^\/+|\/+$/g, '')
let ogKey: string | null = null
if (trimmedPath === '') ogKey = 'index'
else if (STATIC_OG_KEYS.has(trimmedPath)) ogKey = trimmedPath
else if (trimmedPath.startsWith('blog/')) ogKey = trimmedPath

const derivedOgImagePath = ogKey ? `/og/${ogKey}.png` : configData.ogImage
const ogImagePath = ogImageProp ?? derivedOgImagePath
const ogImage = new URL(ogImagePath, Astro.site).toString()
---

<head>
	{googleAnalyticsMeasurementID && <GoogleAnalytics />}
	{googleTagManagerID && <GoogleTagManagerHead />}
	<GoogleSearchConsole />
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<Seo
		title={title}
		description={description}
		ogImage={ogImage}
		canonical={canonical}
		noindex={noindex}
	/>
	<link rel="icon" href={configData.logo.src} type="image/png" />
	<link rel="apple-touch-icon" href={configData.logo.src} />
	<link rel="sitemap" href="/sitemap-index.xml" />
	<meta name="generator" content={Astro.generator} />
	<meta name="theme-color" content="#1fa8c0" />
	<SchemaOrg />
	<ClientRouter fallback="swap" />
</head>
