---
// Global JSON-LD: Organization, WebSite, MobileApplication (iOS + Android),
// SoftwareApplication. Rendered into <head> on every page.
//
// AI engines (ChatGPT, Perplexity, Gemini, Claude) and Google's AI Mode use
// these structured-data blocks to extract canonical facts about the brand,
// the apps, and the canonical site URL.
//
// References:
// - https://schema.org/Organization
// - https://schema.org/WebSite
// - https://schema.org/MobileApplication
// - https://developers.google.com/search/docs/appearance/structured-data/software-app

const SITE = 'https://contextscripture.org'
const APP_NAME = 'The Context Bible'
const APP_DESCRIPTION =
	'A modern Bible app with five context lenses on every verse — Historical Context, Early Church View, ' +
	'Biblical Debates, Cross-References, and original-language Word Study — plus Theme Explain, a ' +
	'daily devotional, the Verse of the Day, and 29 translations across English and Spanish, including ' +
	'the Catholic Public Domain Version, Orthodox Jewish Bible, World Messianic Bible, and the Plain ' +
	'English Version for Aboriginal readers.'

const IOS_URL = 'https://apps.apple.com/us/app/the-context-bible/id6754007140'
const ANDROID_URL =
	'https://play.google.com/store/apps/details?id=com.aspireed.tcb20251014b&hl=en_US'

const organization = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	'@id': `${SITE}/#organization`,
	name: APP_NAME,
	alternateName: 'Context Bible',
	url: SITE,
	logo: `${SITE}/app-icon.png`,
	description: APP_DESCRIPTION,
	email: 'theaspireed@gmail.com',
	founder: {
		'@type': 'Organization',
		name: 'The Aspire Ed Project'
	},
	sameAs: [IOS_URL, ANDROID_URL]
}

const website = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	'@id': `${SITE}/#website`,
	url: SITE,
	name: APP_NAME,
	description: APP_DESCRIPTION,
	publisher: { '@id': `${SITE}/#organization` },
	inLanguage: ['en', 'es']
}

const mobileApplicationIOS = {
	'@context': 'https://schema.org',
	'@type': 'MobileApplication',
	'@id': `${SITE}/#app-ios`,
	name: APP_NAME,
	operatingSystem: 'iOS 14.0+',
	applicationCategory: 'EducationApplication',
	applicationSubCategory: 'BibleStudy',
	description: APP_DESCRIPTION,
	url: IOS_URL,
	downloadUrl: IOS_URL,
	installUrl: IOS_URL,
	softwareVersion: '1.0.7',
	fileSize: '22 MB',
	datePublished: '2025-11-04',
	inLanguage: ['en', 'es'],
	contentRating: '4+',
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'USD'
	},
	aggregateRating: {
		'@type': 'AggregateRating',
		ratingValue: '5.0',
		ratingCount: '12',
		bestRating: '5',
		worstRating: '1'
	},
	publisher: { '@id': `${SITE}/#organization` },
	featureList: [
		'29 Bible translations across English and Spanish (expanding)',
		'Historical Context for every verse',
		'Early Church View — patristic and pre-Reformation interpretation',
		'Biblical Debates — modern scholarly positions in plain English',
		'Cross-References across Scripture',
		'Hebrew and Greek Word Study with lexical data',
		'Ask Bible Questions with cited answers',
		'Theme Explain — definition plus 8–15 hand-picked verses for any biblical theme',
		'Daily Devotional with reflection questions, prayer, and group study guide',
		'Verse of the Day with comments, likes, and sharing',
		'Multi-language responses (English and Español)',
		'Tradition-aware framing (Protestant, Catholic, Orthodox)',
		'Notes, highlights, and saved verses synced across devices',
		'Shareable verse cards in three aspect ratios',
		'10 reading themes and 5 typefaces'
	]
}

const mobileApplicationAndroid = {
	...mobileApplicationIOS,
	'@id': `${SITE}/#app-android`,
	operatingSystem: 'Android',
	url: ANDROID_URL,
	downloadUrl: ANDROID_URL,
	installUrl: ANDROID_URL,
	aggregateRating: undefined // Play Store rating not exposed via a public lookup
}

const schemas = [organization, website, mobileApplicationIOS, mobileApplicationAndroid]
---

{
	schemas.map((s) => (
		<script
			is:inline
			type="application/ld+json"
			set:html={JSON.stringify(s, (_, v) => (v === undefined ? undefined : v))}
		/>
	))
}
