---
// Imports
const { frontmatter, url, slug } = Astro.props

//Layout Components
import Layout from './Layout.astro'

// Section Components
import BlogPostHero from '../components/blocks/blog/BlogPostHero.astro'
import RelatedPosts from '../components/blocks/blog/RelatedPosts.astro'
import SchemaArticle from '../components/scripts/SchemaArticle.astro'
import SchemaBreadcrumb from '../components/scripts/SchemaBreadcrumb.astro'
import SchemaFAQ from '../components/scripts/SchemaFAQ.astro'
import SchemaHowTo from '../components/scripts/SchemaHowTo.astro'

// Content
// - SEO
// Avoid double-stamping the brand: post titles that already contain
// "The Context Bible" or "Context Bible" don't need the suffix.
const postTitle: string = frontmatter.title
const needsSuffix = !/context bible/i.test(postTitle)
const SEO = {
	title: needsSuffix ? `${postTitle} | The Context Bible` : postTitle,
	description: `${frontmatter.description}`
}

const SITE = 'https://contextscripture.org'
const canonical = `${SITE}${url || ''}`
const pubDate: Date = frontmatter.pubDate instanceof Date ? frontmatter.pubDate : new Date(frontmatter.pubDate)
const updatedDate: Date = frontmatter.updatedDate
	? frontmatter.updatedDate instanceof Date
		? frontmatter.updatedDate
		: new Date(frontmatter.updatedDate)
	: pubDate

// Optional per-article AI schemas. Add `faqs` or `howto` to a post's
// frontmatter and the appropriate JSON-LD block will be emitted.
const faqs: { q: string; a: string }[] | undefined = Array.isArray(frontmatter.faqs)
	? frontmatter.faqs
	: undefined
const howto:
	| {
			name: string
			description?: string
			steps: { name: string; text: string }[]
			totalTime?: string
	  }
	| undefined = frontmatter.howto && Array.isArray(frontmatter.howto.steps)
	? frontmatter.howto
	: undefined

// Prefer the explicit slug prop from the dynamic route; fall back to deriving
// it from the URL so the layout still works if it's ever used standalone.
const currentSlug: string =
	slug ?? (url || '').replace(/^\/blog\//, '').replace(/\/$/, '')
---

<Layout title={SEO.title} description={SEO.description}>
	<SchemaArticle
		headline={frontmatter.title}
		description={frontmatter.description}
		datePublished={pubDate.toISOString()}
		dateModified={updatedDate.toISOString()}
		authorName={frontmatter.author || 'The Context Bible team'}
		url={canonical}
		image={frontmatter.image}
		tags={frontmatter.tags}
	/>
	<SchemaBreadcrumb
		items={[
			{ name: 'Home', url: `${SITE}/` },
			{ name: 'Blog', url: `${SITE}/blog` },
			{ name: frontmatter.title, url: canonical }
		]}
	/>
	{faqs && <SchemaFAQ items={faqs} />}
	{howto && (
		<SchemaHowTo
			name={howto.name}
			description={howto.description}
			steps={howto.steps}
			totalTime={howto.totalTime}
			url={canonical}
		/>
	)}
	<BlogPostHero
		tags={frontmatter.tags}
		title={frontmatter.title}
		author={frontmatter.author}
		publishDate={pubDate.toLocaleDateString('en-US', {
			year: 'numeric',
			month: 'long',
			day: 'numeric'
		})}
	/>

	<div class="post-body basic-text basic-text--lg">
		<slot />
	</div>

	<RelatedPosts currentSlug={currentSlug} currentTags={frontmatter.tags} />
</Layout>

<style>
	.post-body {
		@apply mx-auto max-w-3xl px-6 py-12 lg:py-24;
	}
</style>
