---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'
// - UI
import SidebarContent from '../components/blocks/basic/StickySidebar.astro'
import Hero from '../components/blocks/hero/PageHeader.astro'

// Content
// - SEO
const SEO = {
	title: 'Terms of Service — The Context Bible',
	description:
		'Terms of service and use for The Context Bible app and website.'
}
// - Page Header
const header = {
	title: 'Terms of <strong>Service</strong>',
	text: 'The rules of the road for using The Context Bible app and website.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero title={header.title} text={header.text} />
	<SidebarContent>
		<div slot="sidebar">
			<h3>Placeholder</h3>
			<p>
				The full Terms of Service for The Context Bible are being finalized. This page will be
				replaced with the complete terms before the app is widely distributed.
			</p>
		</div>
		<div class="basic-text">
			<h4>About this page</h4>
			<p>
				The Context Bible is currently rolling out, and our final Terms of Service are still
				being prepared. This page is a placeholder; it will be replaced with the complete terms
				before the app is widely distributed.
			</p>
			<p>
				In the meantime, by using The Context Bible app or this website, you agree to use the
				service responsibly: don't attempt to disrupt or circumvent its operation, respect the
				rights of other users, and don't misuse the content. If you have questions, the
				<a href="/contact">contact page</a> is one tap away.
			</p>

			<h4>Privacy snapshot</h4>
			<p>
				The Context Bible app uses your name only to personalize your experience. We don't sell
				your data, we don't target ads with it, and you can update or remove your name from your
				account at any time in the app's Settings.
			</p>

			<h4>Contact</h4>
			<p>
				For any question about these terms or how we handle your data, please reach us through
				the <a href="/contact">contact page</a>.
			</p>
		</div>
	</SidebarContent>
</Layout>
