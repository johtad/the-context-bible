---
// Home page CTA Section
// ------------
// Description: Hero section with headline, subhead, primary CTA, and app icon.

// Components
// - Layout
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - UI
import ChipNotification from '../../ui/ChipNotification.astro'
import Button from '../../ui/Button.astro'
---

<Section id="intro" padding="top" classes="bg-neutral-50 dark:bg-neutral-900">
	<Row>
		<Col span="2" />
		<Col span="8" align="center">
			<img
				src="/app-icon.png"
				alt="The Context Bible app icon"
				width="128"
				height="128"
				class="mx-auto mb-5 h-24 w-24 rounded-3xl shadow-xl shadow-neutral-200 dark:shadow-neutral-950 lg:h-32 lg:w-32"
			/>
			<ChipNotification radius="rounded-full" classes="mb-5">
				Now available on iOS and Android
			</ChipNotification>
			<h1>Read Scripture in its <strong>original context</strong></h1>

			<p class="pb-0 text-lg">
				Five context lenses on every verse — historical setting, early church reading,
				biblical debates, cross-references, and Hebrew/Greek word study. Plus a daily
				devotional. Free.
			</p>
			<div class="mt-6 flex flex-col items-center justify-center gap-3 sm:flex-row">
				<Button size="lg" link="/app">Download free</Button>
				<Button size="lg" style="secondary" link="/read">Read in your browser</Button>
			</div>
		</Col>
		<Col span="2" />
	</Row>
</Section>
