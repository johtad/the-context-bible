---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'
// - UI
import Hero from '../components/blocks/hero/HomeCTA.astro'
import Features from '../components/blocks/features/FeatureCards.astro'
import Testimonial from '../components/blocks/testimonials/BasicDark.astro'
import HighlightBlocks from '../components/blocks/highlights/HightlightRows.astro'
import HomeFAQ from '../components/blocks/FAQ/HomeFAQ.astro'
import TopicBrowser from '../components/blocks/blog/TopicBrowser.astro'
import NewsletterSignup from '../components/blocks/newsletter/NewsletterSignup.astro'
import CTA from '../components/blocks/CTA/BasicDark.astro'
// - Schema
import SchemaFAQ from '../components/scripts/SchemaFAQ.astro'

// Data
import { homeFaqs } from '../data/homeFaqs'

// Content
// - Testimonial background
import testimonialBackground from '../assets/testimonial-bg-01.webp'
// - SEO
const SEO = {
	title: 'The Context Bible — Scripture in its original context',
	description:
		'A free Bible app with five context lenses on every verse: Historical Context, Early Church View, Biblical Debates, Cross-References, and Hebrew/Greek Word Study. Plus a daily devotional and 29 translations across English and Spanish.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<SchemaFAQ items={homeFaqs} />
	<Hero />
	<HomeFAQ />
	<Features />
	<Testimonial
		blockquote="The entrance of thy words giveth light; it giveth understanding unto the simple."
		figcaption="Psalm 119:130"
		cite="King James Version"
		bg={testimonialBackground}
		bgPosition="right"
	/>
	<HighlightBlocks />
	<TopicBrowser />
	<NewsletterSignup source="homepage" />
	<CTA />
</Layout>
