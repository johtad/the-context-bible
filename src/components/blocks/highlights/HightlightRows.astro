---
// Highlights Section
// ------------
// Description: Alternating text blocks with an icon — replaces the prior text+image variant.

// Components
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import { Icon } from 'astro-icon/components'

type HighlightBlock = {
	title: string
	text: string
	icon: string
}
const highlightBlocks: HighlightBlock[] = [
	{
		title: 'Four traditions, <strong>one app</strong>',
		text: "Read with the canon that's home to you — Protestant, Catholic, Orthodox, or the King James tradition. Switch translations and traditions without leaving your place.",
		icon: 'scale'
	},
	{
		title: 'A <strong>reading experience</strong> built for long sessions',
		text: 'Ten themes from Cream to Dusk to Dark. Five typefaces including Georgia, Palatino, and Verdana. Adjustable spacing and font size. Make it feel like your own.',
		icon: 'paint-brush'
	},
	{
		title: 'Save what <strong>speaks to you</strong>',
		text: "Highlight passages, jot notes, and build a personal library of verses you keep returning to. With Premium, your notes and highlights sync across every device you read on.",
		icon: 'rectangle-stack'
	},
	{
		title: 'More than a <strong>translation</strong>',
		text: 'Every passage opens up four lenses: Historical Context, Early Church View, Academic Discourse, and Cross-References. Read the verse, then see what shaped it and what it shaped.',
		icon: 'book'
	}
]
---

<Section id="highlights" classes="bg-neutral-50 dark:bg-neutral-900">
	<Row>
		<Col span="2" />
		<Col span="8">
			<div class="flex flex-col gap-12">
				{
					highlightBlocks.map((block) => (
						<div class="flex flex-col items-start gap-4 lg:flex-row lg:items-center lg:gap-8">
							<div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-primary-50 text-primary-600 dark:bg-primary-950 dark:text-primary-400">
								<Icon name={block.icon} class="h-7 w-7" />
							</div>
							<div>
								<h3 class="mb-2 text-pretty text-xl lg:text-2xl" set:html={block.title} />
								<p class="text-base leading-relaxed text-neutral-600 dark:text-neutral-300">{block.text}</p>
							</div>
						</div>
					))
				}
			</div>
		</Col>
		<Col span="2" />
	</Row>
</Section>
