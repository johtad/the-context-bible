---
// Feature Cards grid Section
// ------------
// Description: A grid of cards with feature information in a 4 column layout.

// Components
// - Layout
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - UI
import Card from '../../ui/cards/FeatureCard.astro'
---

<Section id="features">
	<Row>
		<Col span="12" align="center" classes="mb-8 max-w-4xl mx-auto">
			<h2 class="text-pretty">Built for readers who want to <strong>understand</strong>, not just read</h2>
			<p class="pb-0 text-lg">
				The Bible was written into a context — a time, a place, a people. The Context Bible
				brings that context to every verse, with five lenses, original-language word study,
				and daily devotionals.
			</p>
		</Col>
	</Row>
	<Row>
		<Col span="4">
			<Card
				title="Five context lenses on every verse"
				subtitle="Tap any passage to see Historical Context, Early Church View, Biblical Debates, Cross-References, and Hebrew/Greek Word Study — side by side with the text."
				icon="book"
				link="/features"
			/>
		</Col>
		<Col span="4" classes="flex flex-col gap-6">
			<Card
				title="Ask Bible questions, get real citations"
				subtitle="Ask anything about any verse, doctrine, or theme. Answers come with the sources behind them — scripture, lexica, and scholarship — not guesses."
				icon="chat-bubble-left-right"
				link="/features"
			/>
			<Card
				title="Theme Explain"
				subtitle="Type any biblical theme — forgiveness, covenant, the kingdom of God — and get a tight definition, how it threads through Scripture, and 8–15 verses to start with."
				icon="light-bulb"
				link="/features"
			/>
		</Col>
		<Col span="4" classes="flex flex-col gap-6">
			<Card
				title="Daily Devotional"
				subtitle="A pastoral devotional every day — passage, reflection, key takeaways, prayer, and group study questions. Free, in your pocket, ready when you are."
				icon="filled-star"
				link="/features"
			/>
			<Card
				title="Verse of the Day"
				subtitle="A daily verse delivered to your phone or email — with the context that makes it land. Comment, like, and share with the community."
				icon="sun"
				link="/features"
			/>
		</Col>
	</Row>
</Section>
