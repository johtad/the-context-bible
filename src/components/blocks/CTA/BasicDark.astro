---
// Basic Dark Call To Action section
// ------------
// Description: A centered call to action section that contains: a title, text, background image, notification and a button.

// Components
// - Layout
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - UI
import CTA from '../../ui/CTA.astro'
import Button from '../../ui/Button.astro'
import ChipNotification from '../../ui/ChipNotification.astro'
import Highlight from '../../ui/Highlight.astro'

// Content
import ctaImage from '../../../assets/cta-dark-bg.webp'
---

<Section>
	<Row>
		<Col span="1" />
		<Col span="10">
			<CTA
				title="Download The Context Bible — free"
				text="Available on iOS and Android. Read Scripture with the depth it was written with."
				mode="dark"
				bg={ctaImage}
			>
				<ChipNotification radius="rounded-full" classes="mb-6 box">
					<Highlight> 29 translations • English & Spanish • Free </Highlight>
				</ChipNotification>
				<Button size="lg" style="primary" link="/app"> Download free </Button>
			</CTA>
		</Col>
		<Col span="1" />
	</Row>
</Section>
