---
// Blog Index Page
// ------------
// Description: The blog index page.

// Components
// - Layout
import Layout from '../../layouts/Layout.astro'
// - UI
import Hero from '../../components/blocks/hero/PageHeader.astro'
import BlogPosts from '../../components/blocks/blog/CategorizedBlogPosts.astro'
// - Schema
import SchemaBreadcrumb from '../../components/scripts/SchemaBreadcrumb.astro'

// Data
import { getCollection } from 'astro:content'

// Content
// - SEO
const SEO = {
	title: 'Blog — The Context Bible',
	description:
		'Notes on Scripture in context, study guides, app updates, and pieces from the team behind The Context Bible.'
}
// - Page Header
const header = {
	title: 'The Context <strong>Blog</strong>',
	text: 'Notes on Scripture in context, study guides, and updates from the team.'
}

const allPosts = await getCollection('blog')
---

<Layout title={SEO.title} description={SEO.description}>
	<SchemaBreadcrumb
		items={[
			{ name: 'Home', url: 'https://contextscripture.org/' },
			{ name: 'Blog', url: 'https://contextscripture.org/blog' }
		]}
	/>
	<Hero title={header.title} text={header.text} />
	<BlogPosts data={allPosts} />
</Layout>
