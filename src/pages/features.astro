---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'
// - UI
import Feature from '../components/blocks/features/FeatureSticky.astro'
import Hero from '../components/blocks/hero/PageHeader.astro'
import CTA from '../components/blocks/CTA/BasicDark.astro'

// Data
import featuresData from '../data/json-files/featuresData.json'
// - Feature Categories
const featuresContext = featuresData.filter((feature) => feature.category === 'Context')
const featuresReading = featuresData.filter((feature) => feature.category === 'Reading')
const featuresDaily = featuresData.filter((feature) => feature.category === 'Daily')
const featuresLibrary = featuresData.filter((feature) => feature.category === 'Library')
const featuresSharing = featuresData.filter((feature) => feature.category === 'Sharing')
const featuresPrivacy = featuresData.filter((feature) => feature.category === 'Privacy')

// Content
// - SEO
const SEO = {
	title: 'Features — The Context Bible',
	description:
		'Read with the depth Scripture was written with. Historical, theological, and academic context for every verse — plus reading customization, daily inspiration, and a personal library that syncs across devices.'
}
// - Page Header
const header = {
	title: 'Read with <strong>depth</strong>, not just surface',
	text: 'Every feature is built around one idea: the text deserves to be understood, not just consumed.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero title={header.title} text={header.text} />
	<Feature
		title="Context for every verse"
		text="Four lenses that open up the passage you're reading — its world, its earliest readers, its scholarly debates, and its echoes elsewhere in Scripture."
		data={featuresContext}
	/>
	<Feature
		title="A reading experience built for long sessions"
		text="Translations, traditions, themes, and typefaces — set the app up the way your eyes and your tradition expect."
		data={featuresReading}
		classes="bg-neutral-50 dark:bg-neutral-900"
	/>
	<Feature
		title="Daily and weekly rhythms"
		text="Verse of the Day, Weekly Context Insights, delivered on your schedule."
		data={featuresDaily}
	/>
	<Feature
		title="Your personal library"
		text="Save the verses that stop you. Highlight the words that move you. Notes that follow you across devices."
		data={featuresLibrary}
		classes="bg-neutral-50 dark:bg-neutral-900"
	/>
	<Feature
		title="Share what speaks to you"
		text="Verse cards designed for every social platform — and made to feel like yours, not a template."
		data={featuresSharing}
	/>
	<Feature
		title="A quiet account experience"
		text="No tracking, no ad targeting, no surprises. Your reading life is yours."
		data={featuresPrivacy}
		classes="bg-neutral-50 dark:bg-neutral-900"
	/>
	<CTA />
</Layout>
