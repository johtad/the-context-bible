---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'
// - UI
import Hero from '../components/blocks/hero/PageHeader.astro'
import FAQ from '../components/blocks/FAQ/FaqSticky.astro'
import CTA from '../components/blocks/CTA/BasicDark.astro'
// - Schema
import SchemaFAQ from '../components/scripts/SchemaFAQ.astro'
import SchemaBreadcrumb from '../components/scripts/SchemaBreadcrumb.astro'

// Data
import faqData from '../data/json-files/faqData.json'
// - FAQ Categories
const faqGeneral = faqData.filter((faq) => faq.category === 'general')
const faqFeatures = faqData.filter((faq) => faq.category === 'features')
const faqPricing = faqData.filter((faq) => faq.category === 'pricing')

// FAQs flattened for JSON-LD
const faqSchemaItems = faqData.map((f) => ({ q: f.question, a: f.reply }))

// Content
// - SEO
const SEO = {
	title: 'FAQ — The Context Bible',
	description:
		'Answers to common questions about The Context Bible — what it is, who it is for, which translations and traditions are supported, and how your data is handled.'
}
// - Page Header
const header = {
	title: 'Questions, <strong>answered</strong>',
	text: 'Everything you might want to know before downloading. If something is missing, the contact page is one tap away.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<SchemaFAQ items={faqSchemaItems} />
	<SchemaBreadcrumb
		items={[
			{ name: 'Home', url: 'https://contextscripture.org/' },
			{ name: 'FAQ', url: 'https://contextscripture.org/faq' }
		]}
	/>
	<Hero title={header.title} text={header.text} />
	<FAQ
		title="About the app"
		text="The big-picture questions — what The Context Bible is, who it is for, and how it differs from other Bible apps."
		data={faqGeneral}
	/>
	<FAQ
		title="Features and reading"
		text="Translations, traditions, context panels, notes, highlights, and the everyday details of using the app."
		data={faqFeatures}
		classes="bg-neutral-50 dark:bg-neutral-900"
	/>
	<FAQ
		title="Cost, privacy, and accounts"
		text="What's included, how we handle your data, and how to sign in."
		data={faqPricing}
	/>
	<CTA />
</Layout>
