---
// Basic Cards grid Section
// ------------
// Description: A grid of cards with basic contact information in a 4 column layout.
// Properties:
// - classes: Additional classes to be added to the Section

// Components
// - Layout
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - UI
import Card from '../../ui/cards/BasicCard.astro'

// 	Props
type Props = {
	classes?: string
}
const { classes } = Astro.props
---

<Section id="requests" classes={classes}>
	<Row>
		<Col span="12" align="center" classes="mb-12 max-w-4xl mx-auto">
			<h2 class="text-balance">Or just email us <strong>directly</strong></h2>
			<p class="pb-0 text-lg">
				Forms work, but if you'd rather send an email, here is what reaches us fastest.
			</p>
		</Col>
	</Row>
	<Row>
		<Col span="4">
			<Card
				title="General questions"
				subtitle="Anything about the app, the project, or what we're working on — send it to theaspireed@gmail.com and we'll write back."
				icon="chat-bubble-left-ellipsis"
				classes="text-center dark:!bg-neutral-800/50"
				link="mailto:theaspireed@gmail.com"
			/>
		</Col>
		<Col span="4">
			<Card
				title="Feature requests"
				subtitle="Have an idea to make The Context Bible better? Tell us. We read every suggestion that comes in."
				icon="bolt"
				classes="text-center dark:!bg-neutral-800/50"
				link="mailto:theaspireed@gmail.com?subject=Feature%20request"
			/>
		</Col>
		<Col span="4" classes="flex flex-col gap-6">
			<Card
				title="Bug reports"
				subtitle="If something is broken, please describe what you were doing when it happened. Screenshots help."
				icon="bug-ant"
				classes="text-center dark:!bg-neutral-800/50"
				link="mailto:theaspireed@gmail.com?subject=Bug%20report"
			/>
		</Col>
	</Row>
</Section>
