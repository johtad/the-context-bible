---
import Layout from '../layouts/Layout.astro'
import SchemaBreadcrumb from '../components/scripts/SchemaBreadcrumb.astro'
import '../styles/guide-page.css'

const SEO = {
	title: '10 Verses That Mean Something Different Once You Know the History — free guide',
	description:
		'A short, free PDF guide from The Context Bible. Ten familiar verses whose meaning shifts once you know the historical setting they were written into.'
}
const SITE = 'https://contextscripture.org'
const apiBase = 'https://bible-app-3.onrender.com'
---

<Layout title={SEO.title} description={SEO.description} classes="guide-page">
	<SchemaBreadcrumb
		items={[
			{ name: 'Home', url: `${SITE}/` },
			{ name: 'Free guide', url: `${SITE}/guide` }
		]}
	/>

	<!-- HERO -->
	<section class="hero">
		<div class="wrap hero-inner">
			<div>
				<div class="kicker">A free guide</div>
				<h1>10 Verses That Mean Something Different Once You Know the <em>History</em></h1>
				<p class="lede">
					The Bible was written into a world — a time, a place, a people. Step back into
					it, and familiar verses open up in ways you may never have seen.
				</p>
			</div>

			<div class="card" id="card">
				<div id="formview" data-formview>
					<h2>Send me the free guide</h2>
					<p class="sub">A short, free guide — yours in one click.</p>
					<form data-newsletter-form data-source="guide-page" novalidate>
						<label for="guide-name">First name</label>
						<input
							id="guide-name"
							type="text"
							name="name"
							placeholder="Your first name"
							autocomplete="given-name"
							maxlength="80"
						/>
						<label for="guide-email">Email address</label>
						<input
							id="guide-email"
							type="email"
							name="email"
							placeholder="you@example.com"
							autocomplete="email"
							required
							maxlength="254"
						/>
						<input
							type="text"
							name="website"
							class="honeypot"
							tabindex="-1"
							autocomplete="off"
							aria-hidden="true"
						/>
						<button type="submit" class="cta" data-newsletter-submit>
							<span data-newsletter-submit-label>Send me the free guide</span>
						</button>
					</form>
					<p class="status" data-newsletter-status role="status" aria-live="polite"></p>
					<div class="reassure">
						<svg
							width="15"
							height="15"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
						>
							<path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5l-8-3z"></path>
						</svg>
						We'll never share your email. Unsubscribe anytime.
					</div>
				</div>

				<div class="thanks" data-thanksview>
					<div class="check">
						<svg
							width="26"
							height="26"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2.4"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<path d="M20 6 9 17l-5-5"></path>
						</svg>
					</div>
					<h2>Check your inbox</h2>
					<p>
						We just sent a confirmation link. Open it and your free guide will arrive in your
						inbox right away. If you don't see it in a minute, peek in your promotions or
						spam folder.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- INSIDE -->
	<section class="inside">
		<div class="wrap">
			<div class="sec-label">A look inside</div>
			<h3>The same words, a deeper meaning</h3>
			<p class="isub">Three of the ten you'll find in the guide.</p>
			<div class="teasers">
				<div class="teaser">
					<div class="ref">Revelation 3:15–16</div>
					<h4>"Lukewarm" was never about being half-hearted</h4>
					<p>
						Laodicea's water arrived warm and undrinkable, while neighboring towns had hot
						springs and cold streams. The rebuke is being useless — not being undecided.
					</p>
				</div>
				<div class="teaser">
					<div class="ref">Matthew 19:24</div>
					<h4>There was no gate called "the Needle's Eye"</h4>
					<p>
						No evidence such a gate ever existed; the idea appears a thousand years later.
						Jesus meant a flat impossibility — then said God makes the impossible possible.
					</p>
				</div>
				<div class="teaser">
					<div class="ref">Luke 15:20</div>
					<h4>The father humiliated himself to reach his son</h4>
					<p>
						A dignified elder did not run in public. To run, he had to take on shame — a
						father willing to be humbled to restore his child.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- CLOSING -->
	<section class="closing">
		<div class="wrap">
			<p class="verse">
				"The entrance of thy words giveth light; it giveth understanding unto the simple."
			</p>
			<div class="ref2">Psalm 119:130</div>
			<a href="#card" class="ghost">Get the free guide →</a>
		</div>
	</section>
</Layout>

<!-- Load the brand fonts only on this page. -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,500&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&display=swap"
	rel="stylesheet"
/>

<script is:inline define:vars={{ apiBase }}>
	(function () {
		const form = document.querySelector('body.guide-page [data-newsletter-form]')
		if (!form) return
		const formView = document.querySelector('[data-formview]')
		const thanksView = document.querySelector('[data-thanksview]')
		const submit = form.querySelector('[data-newsletter-submit]')
		const submitLabel = form.querySelector('[data-newsletter-submit-label]')
		const status = document.querySelector('[data-newsletter-status]')
		const setStatus = (text, kind) => {
			if (!status) return
			status.textContent = text || ''
			if (kind) status.setAttribute('data-state', kind)
			else status.removeAttribute('data-state')
		}
		const setBusy = (busy) => {
			if (submit) submit.disabled = busy
			if (submitLabel) submitLabel.textContent = busy ? 'Sending…' : 'Send me the free guide'
		}
		const track = (outcome) => {
			if (typeof window.gtag === 'function') {
				window.gtag('event', 'newsletter_signup', { outcome, source: 'guide-page' })
			}
		}
		form.addEventListener('submit', async (e) => {
			e.preventDefault()
			const data = new FormData(form)
			const email = String(data.get('email') || '').trim()
			const name = String(data.get('name') || '').trim()
			const honeypot = String(data.get('website') || '').trim()
			if (honeypot) {
				formView.classList.add('is-hidden')
				thanksView.classList.add('is-active')
				return
			}
			if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
				setStatus('Please enter a valid email address.', 'error')
				return
			}
			setStatus('', null)
			setBusy(true)
			try {
				const res = await fetch(`${apiBase}/api/newsletter/subscribe`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ email, name, source: 'guide-page' })
				})
				const payload = await res.json().catch(() => ({}))
				if (!res.ok || !payload.ok) {
					setStatus(payload.error || 'Something went wrong. Please try again.', 'error')
					track('error')
					setBusy(false)
					return
				}
				formView.classList.add('is-hidden')
				thanksView.classList.add('is-active')
				track(payload.status === 'already_confirmed' ? 'already_confirmed' : 'pending')
			} catch (err) {
				console.error('[guide signup]', err)
				setStatus('Could not reach the server. Please try again in a moment.', 'error')
				track('network_error')
			} finally {
				setBusy(false)
			}
		})
	})()
</script>
